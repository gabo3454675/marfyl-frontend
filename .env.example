# =============================================================================
# Frontend (Next.js) - Variables de entorno
# Copiar a .env.local y completar los valores antes de levantar el client.
# =============================================================================

# -----------------------------------------------------------------------------
# API (obligatorio para producción)
# -----------------------------------------------------------------------------
# URL base del API (backend). En desarrollo: http://localhost:3001/api
# Producción (marfyl.site): API en subdominio api.marfyl.site
# Sin esta variable en producción, el login falla con "Cannot POST /auth/login" porque las peticiones irían a localhost.
# Desarrollo local (ajustar puerto al del server). Producción ejemplo:
# NEXT_PUBLIC_API_URL=https://api.marfyl.site/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Vista previa sin login: dashboard, POS, facturas, fiscal (solo desarrollo)
# NEXT_PUBLIC_FISCAL_PREVIEW=true
# NEXT_PUBLIC_FISCAL_PREVIEW=false  # desactivar en dev

# Módulo temporal: boletería / concierto (Hemenegilda Capacidad)
NEXT_PUBLIC_FEATURE_CONCERT=true
NEXT_PUBLIC_CONCERT_SLUG=hemenegilda-capacidad

# Reserva temporal en checkout (debe coincidir con CONCERT_HOLD_MINUTES del backend)
# NEXT_PUBLIC_CONCERT_HOLD_MINUTES=20

# Soporte WhatsApp boletería (clientes con problemas en la compra)
# NEXT_PUBLIC_CONCERT_SUPPORT_WHATSAPP_URL=https://wa.me/qr/CXXGWJDUIWSWD1

# -----------------------------------------------------------------------------
# Nota
# -----------------------------------------------------------------------------
# NODE_ENV lo define Next.js automáticamente (development | production).
# Solo las variables con prefijo NEXT_PUBLIC_ están disponibles en el navegador.
